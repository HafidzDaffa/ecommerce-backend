# Application
APP_NAME=ecommerce-backend
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ecommerce_db
DB_SSL_MODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT Configuration
JWT_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32
JWT_EXPIRATION=24h

# Google Drive Configuration
GOOGLE_DRIVE_CREDENTIALS_PATH=./credentials.json
GOOGLE_DRIVE_FOLDER_ID=your-folder-id-here
STORAGE_TYPE=local

# Xendit Payment Configuration
XENDIT_API_KEY=your-xendit-secret-api-key-here
XENDIT_CALLBACK_TOKEN=your-xendit-callback-verification-token-here
